# ==========================================
# Настройки окружения AnalystAutoFlow
# ==========================================

# --- 1. Настройки сборки Docker & Airflow ---
AIRFLOW_IMAGE_NAME=airflow-custom-java:latest
# UID пользователя (в Linux/macOS узнай командой 'id -u'. На Windows оставь 50000)
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.

# Секретный ключ для шифрования подключений и паролей внутри Airflow.
# Сгенерируй свой ключ командой в терминале:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here

# --- 2. Доступы к панели управления Airflow (Web UI) ---
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=your_super_secret_password

# --- 3. Настройки системной базы (Метаданные Airflow) ---
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow_system_db_password
POSTGRES_DB=airflow

# --- 4. Настройки аналитического хранилища (Куда ходят DAGи) ---
EXTRA_DB_USER=analyst_role
EXTRA_DB_PASSWORD=analyst_db_password
EXTRA_DB_NAME=analytics_dwh
